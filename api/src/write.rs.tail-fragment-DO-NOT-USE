            .await
            .expect("response");
        assert_eq!(
            bool_config_response.status(),
            StatusCode::UNPROCESSABLE_ENTITY
        );
        let json = json_body(bool_config_response).await;
        assert_eq!(json["error"]["code"], "validation_failed");
